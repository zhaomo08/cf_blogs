---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

type PostSummary = {
  id: string;
  title: string;
  description: string;
  tags: string[];
  href: string;
  dateLabel: string;
};

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = [...posts].sort((a, b) => {
  const aTs = a.data.date ? a.data.date.valueOf() : 0;
  const bTs = b.data.date ? b.data.date.valueOf() : 0;
  return bTs - aTs;
});

const postSummaries: PostSummary[] = sorted.map((post) => {
  const locale = post.id.startsWith('en/') ? 'en-US' : 'zh-CN';
  const dateLabel = post.data.date
    ? post.data.date.toLocaleDateString(locale, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      })
    : '';

  return {
    id: post.id,
    title: post.data.title,
    description: post.data.description ?? '',
    tags: (post.data.tags ?? []).map((tag) => String(tag || '').trim()).filter(Boolean),
    href: `/blog/${post.id.split('/').map((segment) => encodeURIComponent(segment)).join('/')}`,
    dateLabel,
  };
});

const tagCountMap = new Map<string, number>();
for (const post of postSummaries) {
  for (const tag of post.tags) {
    tagCountMap.set(tag, (tagCountMap.get(tag) ?? 0) + 1);
  }
}

const maxTagCount = Math.max(...tagCountMap.values(), 1);
const tagCloud = [...tagCountMap.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count], index) => {
    const ratio = count / maxTagCount;
    const jitter = [0.06, 0.02, -0.03, -0.06][index % 4];
    const size = Math.max(0.92, Math.min(1.65, 0.95 + ratio * 0.65 + jitter));
    const delay = (index % 7) * 0.18;
    return { tag, count, size: Number(size.toFixed(2)), delay: Number(delay.toFixed(2)) };
  });

const tagGroups = tagCloud.map((item) => ({
  ...item,
  posts: postSummaries.filter((post) => post.tags.includes(item.tag)),
}));
---
<BaseLayout title="搜索 / Search" description="搜索博客文章">
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>
  <main class="container">
    <h1>搜索 / Search</h1>
    <div id="search"></div>

    <section class="tag-browser">
      <div class="tag-browser-head">
        <h2>标签 / Tags</h2>
        <button id="clear-tag" class="clear-tag" hidden>清除筛选</button>
      </div>
      <div class="tag-cloud" id="tag-cloud">
        {tagCloud.length === 0 ? (
          <p class="empty">暂无标签 / No tags</p>
        ) : (
          tagCloud.map((item) => (
            <button
              type="button"
              class="tag-float"
              data-tag={item.tag}
              style={`font-size:${item.size}rem;animation-delay:${item.delay}s;`}
            >
              <span>{item.tag}</span>
              <small>{item.count}</small>
            </button>
          ))
        )}
      </div>
    </section>

    <section class="tag-results" id="tag-results" hidden>
      <h2 id="tag-results-title"></h2>
      {tagGroups.map((group) => (
        <div class="tag-group" data-tag-group={group.tag} hidden>
          {group.posts.length === 0 ? (
            <p class="empty">该标签下暂无文章 / No posts under this tag</p>
          ) : (
            <ul>
              {group.posts.map((post) => (
                <li>
                  <a href={post.href}>{post.title}</a>
                  {post.dateLabel && <small>{post.dateLabel}</small>}
                  {post.description && <p>{post.description}</p>}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </section>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', function() {
        if (typeof window.PagefindUI === 'function') {
          new window.PagefindUI({
            element: '#search',
            showImages: true,
            showEmptyFilters: false,
            highlightParam: 'highlight',
          });
        }

        const tagButtons = Array.from(document.querySelectorAll('.tag-float'));
        const clearButton = document.getElementById('clear-tag');
        const resultWrap = document.getElementById('tag-results');
        const resultTitle = document.getElementById('tag-results-title');
        const tagGroups = Array.from(document.querySelectorAll('[data-tag-group]'));

        if (!clearButton || !resultWrap || !resultTitle) {
          return;
        }

        function showTagGroup(tag) {
          let matched = false;
          tagGroups.forEach((group) => {
            const visible = group.getAttribute('data-tag-group') === tag;
            group.hidden = !visible;
            if (visible) matched = true;
          });
          return matched;
        }

        function setActiveTag(tag) {
          tagButtons.forEach((button) => {
            const active = button.dataset.tag === tag;
            button.classList.toggle('active', active);
          });

          const matched = showTagGroup(tag);
          if (!matched) return;

          const countText = tagButtons.find((button) => button.dataset.tag === tag)
            ?.querySelector('small')
            ?.textContent?.trim() || '0';
          resultTitle.textContent = `#${tag} (${countText})`;
          resultWrap.hidden = false;
          clearButton.hidden = false;

          const url = new URL(window.location.href);
          url.searchParams.set('tag', tag);
          window.history.replaceState({}, '', url);
        }

        function clearActiveTag() {
          tagButtons.forEach((button) => button.classList.remove('active'));
          tagGroups.forEach((group) => {
            group.hidden = true;
          });
          resultWrap.hidden = true;
          clearButton.hidden = true;

          const url = new URL(window.location.href);
          url.searchParams.delete('tag');
          window.history.replaceState({}, '', url);
        }

        tagButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const tag = button.dataset.tag || '';
            if (!tag) return;
            if (button.classList.contains('active')) {
              clearActiveTag();
              return;
            }
            setActiveTag(tag);
          });
        });

        clearButton.addEventListener('click', clearActiveTag);

        const initialTag = new URLSearchParams(window.location.search).get('tag');
        if (initialTag && tagButtons.some((button) => button.dataset.tag === initialTag)) {
          setActiveTag(initialTag);
        }
      });
    </script>
  </Fragment>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }
  h1 {
    margin-bottom: 1.5rem;
  }
  .tag-browser {
    margin-top: 2rem;
    padding: 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-secondary);
  }
  .tag-browser-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }
  .tag-browser-head h2 {
    margin: 0;
    font-size: 1rem;
  }
  .clear-tag {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-muted);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
    cursor: pointer;
    font-size: 0.82rem;
  }
  .clear-tag:hover {
    color: var(--color-accent);
  }
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.7rem;
  }
  .tag-float {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 999px;
    padding: 0.34rem 0.72rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.42rem;
    cursor: pointer;
    animation: floatY 3.2s ease-in-out infinite;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .tag-float:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .tag-float small {
    font-size: 0.7em;
    opacity: 0.75;
  }
  .tag-float.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
  .tag-results {
    margin-top: 1.3rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem 1.1rem;
  }
  .tag-results h2 {
    margin: 0 0 0.8rem;
    font-size: 1rem;
  }
  .tag-results ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .tag-results li {
    border: 1px solid var(--color-border);
    border-radius: 9px;
    padding: 0.78rem 0.9rem;
    background: var(--color-bg-secondary);
  }
  .tag-results li a {
    font-weight: 600;
    color: var(--color-text);
  }
  .tag-results li a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .tag-results li small {
    display: block;
    margin-top: 0.26rem;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }
  .tag-results li p {
    margin: 0.4rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }
  .empty {
    color: var(--color-text-muted);
    margin: 0;
  }
  @keyframes floatY {
    0% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
    100% { transform: translateY(0); }
  }
</style>
