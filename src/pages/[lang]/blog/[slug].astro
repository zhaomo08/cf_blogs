---
import { getCollection } from 'astro:content';
import { SUPPORTED_LANGS, type Lang } from '../../../i18n/index';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id, data }) => {
    if (data.draft) return false;
    return SUPPORTED_LANGS.some((lang) => id.startsWith(`${lang}/`));
  });

  return posts.map((post) => {
    const [lang, slug] = post.id.split('/');
    return {
      params: { lang, slug },
    };
  });
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const encodedLang = encodeURIComponent(lang);
const encodedSlug = slug.split('/').map((segment) => encodeURIComponent(segment)).join('/');
return Astro.redirect(`/blog/${encodedLang}/${encodedSlug}`, 301);
---
